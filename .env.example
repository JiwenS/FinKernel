# App runtime
ENVIRONMENT=development
API_PREFIX=/api

# PostgreSQL
POSTGRES_DB=finkernel
POSTGRES_USER=finkernel
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://finkernel:change-me@localhost:5432/finkernel
ENABLE_PGVECTOR=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Broker routing (V1 = Alpaca paper only)
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Discord HITL (V1 = Discord only)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_COMMAND_PREFIX=!
DISCORD_ALLOWED_USER_IDS_CSV=

# Policy defaults
ALLOWED_SYMBOLS_CSV=AAPL,MSFT,SPY
MAX_LIMIT_ORDER_NOTIONAL=5000
MAX_LIMIT_ORDER_QTY=100
DEFAULT_TIME_IN_FORCE=day
