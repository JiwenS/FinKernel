# Phase 1 local defaults
APP_NAME=FinKernel
ENVIRONMENT=development
API_PREFIX=/api

# FinKernel runs on PostgreSQL with pgvector in Phase 1.
DATABASE_URL=postgresql+psycopg://finkernel:change-me@localhost:5432/finkernel
ENABLE_PGVECTOR=true

# Seed risk profiles used for local bootstrap and demos.
PROFILE_STORE_PATH=config/persona-profiles.json
