# Local settings for FinKernel.
# Use file mode for Lite local profile generation.
STORAGE_BACKEND=file
PROFILE_DATA_DIR=.finkernel

# Host port exposed by the FinKernel HTTP app.
APP_PORT=8000

# PostgreSQL credentials used only when STORAGE_BACKEND=database.
POSTGRES_DB=finkernel
POSTGRES_USER=finkernel
POSTGRES_PASSWORD=change-me
